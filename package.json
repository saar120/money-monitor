{
  "name": "money-monitor",
  "version": "0.1.0-alpha.1",
  "description": "",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:all": "npm run dev & npm run dashboard:dev & wait",
    "build": "tsc && cp -r src/db/migrations dist/db/migrations && cd dashboard && npm run build",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build",
    "mcp": "tsx src/mcp-server.ts",
    "postinstall": "npx patch-package",
    "backup": "bash scripts/backup.sh",
    "restore": "bash scripts/restore.sh",
    "electron:dev": "npm run build && tsc -p electron/tsconfig.json && npm run electron:rebuild && electron .",
    "electron:build": "npm run build && tsc -p electron/tsconfig.json && npm run electron:rebuild && electron-builder",
    "electron:rebuild": "node scripts/electron-rebuild.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:36222/git/saar120/money-monitor"
  },
  "workspaces": [
    "dashboard"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.money-monitor.app",
    "productName": "Money Monitor",
    "icon": "electron/icons/icon",
    "mac": {
      "target": "dmg",
      "icon": "electron/icons/icon.icns",
      "category": "public.app-category.finance"
    },
    "win": {
      "icon": "electron/icons/icon.ico"
    },
    "linux": {
      "icon": "electron/icons/icon-256.png"
    },
    "files": [
      "dist/**/*",
      "dashboard/dist/**/*",
      "electron/**/*.js",
      "electron/**/*.mjs",
      "electron/icons/**/*",
      "node_modules/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/puppeteer-core/**"
    ],
    "publish": null
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@mariozechner/pi-agent-core": "^0.57.1",
    "@mariozechner/pi-ai": "^0.57.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sinclair/typebox": "^0.34.48",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.7.4",
    "grammy": "^1.41.1",
    "israeli-bank-scrapers": "^6.7.1",
    "node-cron": "^4.2.1",
    "pino-pretty": "^13.1.3",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "tar": "^7.5.11",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.0",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
