{
  "name": "money-monitor",
  "version": "0.2.0",
  "description": "",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dashboard:dev\"",
    "build": "tsc && shx rm -rf dist/db/migrations && shx cp -r src/db/migrations dist/db/migrations && npm run dashboard:build",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build",
    "mcp": "tsx src/mcp-server.ts",
    "postinstall": "npx patch-package",
    "electron:prebuild": "npm run build && tsc -p electron/tsconfig.json && npm run electron:rebuild",
    "electron:dev": "npm run electron:prebuild && electron .",
    "electron:build": "npm run electron:prebuild && electron-builder --mac",
    "electron:build:win": "npm run electron:prebuild && electron-builder --win",
    "electron:build:linux": "npm run electron:prebuild && electron-builder --linux",
    "electron:build:all": "npm run electron:prebuild && electron-builder --mac --win --linux",
    "electron:rebuild": "node scripts/electron-rebuild.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.vue": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:36222/git/saar120/money-monitor"
  },
  "workspaces": [
    "dashboard"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.money-monitor.app",
    "productName": "Money Monitor",
    "icon": "electron/icons/icon",
    "mac": {
      "target": "zip",
      "icon": "electron/icons/icon.icns",
      "category": "public.app-category.finance"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/icons/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/icons/icon-256.png"
    },
    "files": [
      "dist/**/*",
      "dashboard/dist/**/*",
      "electron/**/*.js",
      "electron/**/*.mjs",
      "electron/icons/**/*",
      "node_modules/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/puppeteer-core/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "saar120",
      "repo": "money-monitor"
    }
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@mariozechner/pi-agent-core": "^0.57.1",
    "@mariozechner/pi-ai": "^0.57.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@puppeteer/browsers": "^2.3.0",
    "@sinclair/typebox": "^0.34.48",
    "better-sqlite3": "^12.6.2",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "electron-updater": "^6.8.3",
    "fastify": "^5.7.4",
    "grammy": "^1.41.1",
    "israeli-bank-scrapers-core": "^6.7.1",
    "node-cron": "^4.2.1",
    "pino-pretty": "^13.1.3",
    "tar": "^7.5.11",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.0",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "shx": "^0.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0"
  }
}
